  dryRun             Boolean            @default(false) @map("dry_run")
  tableCounts        Json?              @map("table_counts")
  insertedCounts     Json?              @map("inserted_counts")
  updatedCounts      Json?              @map("updated_counts")
  skippedCounts      Json?              @map("skipped_counts")
  failureCounts      Json?              @map("failure_counts")
  orphanCounts       Json?              @map("orphan_counts")
  fileCounts         Json?              @map("file_counts")
