}

model MigrationFailure {
  id             String   @id @default(uuid()) @db.Uuid
  runId          String   @map("run_id") @db.Uuid
  tableName      String   @map("table_name")
  convexId       String?  @map("convex_id")
  reasonCode     String   @map("reason_code")
  /// Safe, redacted detail — never store secrets or full hashes.
  safeDetail     String?  @map("safe_detail")
  createdAt      DateTime @default(now()) @map("created_at")

  run MigrationRun @relation(fields: [runId], references: [id], onDelete: Restrict)

  @@index([runId])
  @@index([tableName])
