}

// ─── Phase 4: local Nest auth (sessions / reset / audit) ───

enum AuthAuditAction {
  login_success
  login_failure
  logout
  logout_all
  password_change
  password_reset_request
  password_reset_success
  password_reset_failure
  session_revoked
  rehash_success
  rehash_failure
  register_success
  register_failed
}

model Session {
  id                 String    @id @default(uuid()) @db.Uuid
  userId             String    @map("user_id") @db.Uuid
  /// SHA-256 hex of the raw session token (never store raw token).
  tokenHash          String    @unique @map("token_hash")
  createdAt          DateTime  @default(now()) @map("created_at")
  lastSeenAt         DateTime  @default(now()) @map("last_seen_at")
  expiresAt          DateTime  @map("expires_at")
  absoluteExpiresAt  DateTime  @map("absolute_expires_at")
  revokedAt          DateTime? @map("revoked_at")
  /// HMAC/SHA-256 of client IP (never store raw IP).
  ipHash             String?   @map("ip_hash")
  /// SHA-256 of user-agent string.
  userAgentHash      String?   @map("user_agent_hash")

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model PasswordResetToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  /// SHA-256 hex of raw reset token.
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  usedAt     DateTime? @map("used_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  /// Optional request metadata hashes (no secrets).
  ipHash     String?   @map("ip_hash")

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model AuthAuditEvent {
  id         String          @id @default(uuid()) @db.Uuid
  userId     String?         @map("user_id") @db.Uuid
  action     AuthAuditAction
  /// Safe metadata only (no passwords, tokens, or hashes).
  metadata   Json?
  ipHash     String?         @map("ip_hash")
  createdAt  DateTime        @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("auth_audit_events")
}

enum ProfileAuditAction {
  profile_ensure
  profile_update
  profile_gender_complete
  questionnaire_autosave
  questionnaire_update
  questionnaire_complete
  preferences_upsert
  wali_update
  photo_sign_upload
  photo_confirm
  photo_delete
  photo_reorder
  score_recalc_stub
}

model ProfileAuditEvent {
  id         String             @id @default(uuid()) @db.Uuid
  userId     String             @map("user_id") @db.Uuid
  profileId  String?            @map("profile_id") @db.Uuid
  action     ProfileAuditAction
  /// Safe metadata only (no secrets, no signed URLs).
  metadata   Json?
  createdAt  DateTime           @default(now()) @map("created_at")

