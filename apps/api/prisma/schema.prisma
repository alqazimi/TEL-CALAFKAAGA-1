  profile Profile? @relation(fields: [profileId], references: [id], onDelete: Restrict)

  @@index([userId, createdAt])
  @@index([profileId, createdAt])
  @@index([action, createdAt])
  @@map("profile_audit_events")
}

// ─── Phase 8: Stripe webhook events + mail delivery ───

enum StripeWebhookStatus {
  received
  processing
  completed
  failed
}

enum MailDeliveryStatus {
  queued
  sent
  failed
  skipped
}

model StripeWebhookEvent {
  id            String              @id @default(uuid()) @db.Uuid
  stripeEventId String              @unique @map("stripe_event_id")
  eventType     String              @map("event_type")
  receivedAt    DateTime            @default(now()) @map("received_at")
  processedAt   DateTime?           @map("processed_at")
  status        StripeWebhookStatus @default(received)
  error         String?
  /// SHA-256 of raw body — never store full card/PII payloads.
  payloadHash   String              @map("payload_hash")
  retryCount    Int                 @default(0) @map("retry_count")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  @@index([status, receivedAt])
  @@index([eventType, receivedAt])
  @@map("stripe_webhook_events")
}

model MailDelivery {
  id              String             @id @default(uuid()) @db.Uuid
  /// Dedup key e.g. payment:completed:{paymentId}
  idempotencyKey  String             @unique @map("idempotency_key")
  userId          String?            @map("user_id") @db.Uuid
  /// SHA-256 of recipient email — never store raw address in this table.
  toHash          String             @map("to_hash")
  template        String
  subject         String
  status          MailDeliveryStatus @default(queued)
  error           String?
  sentAt          DateTime?          @map("sent_at")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@map("mail_deliveries")
}
