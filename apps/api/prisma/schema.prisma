model MediaObject {
  id                   String                @id @default(uuid()) @db.Uuid
  convexStorageId      String                @unique @map("convex_storage_id")
  purpose              MediaPurpose          @default(unknown)
  bucket               String?               @map("bucket")
  /// Deterministic key: `{convexStorageId}.{ext}` within the purpose bucket.
  objectKey            String?               @map("object_key")
  contentType          String?               @map("content_type")
  sizeBytes            BigInt?               @map("size_bytes")
  checksumSha256       String?               @map("checksum_sha256")
  ownerUserId          String?               @map("owner_user_id") @db.Uuid
  /// Convex user id when owner is known from export refs; null if unresolved.
  convexOwnerUserId    String?               @map("convex_owner_user_id")
  migrationStatus      MediaMigrationStatus  @default(pending) @map("migration_status")
  /// Primary source table that determined purpose (profiles, messages, …).
  sourceTable          String?               @map("source_table")
  sourceRecordConvexId String?               @map("source_record_convex_id")
  /// All known references: [{table,recordId,field,purpose,ownerConvexUserId}]
  sourceRefs           Json?                 @map("source_refs")
  migratedAt           DateTime?             @map("migrated_at")
  failureReason        String?               @map("failure_reason")
  verifiedReadable     Boolean               @default(false) @map("verified_readable")
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")

  owner   User?        @relation(fields: [ownerUserId], references: [id], onDelete: Restrict)
  uploads UserUpload[]

  @@unique([bucket, objectKey])
  @@index([purpose])
  @@index([migrationStatus])
  @@index([ownerUserId])
  @@map("media_objects")
}

model MigrationRun {
  id                 String             @id @default(uuid()) @db.Uuid
  sourceExportPath   String             @map("source_export_path")
  sourceExportHash   String             @map("source_export_hash")
  startedAt          DateTime           @default(now()) @map("started_at")
  completedAt        DateTime?          @map("completed_at")
