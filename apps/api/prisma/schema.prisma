// Phase 1 Prisma schema — mirrors audited Convex persistent tables.
// Sessions, refresh tokens, verification codes, OAuth verifiers,
// typing indicators, and rate-limit buckets are intentionally omitted.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Gender {
  male
  female
}

enum UserRole {
  user
  admin
  owner
}

enum ReviewStatus {
  incomplete
  pending_review
  approved
  rejected
  suspended
}

enum PhotoVisibility {
  everyone
  matches
  private
}

enum LikeAction {
  like
  pass
  shortlist
}

enum MatchStatus {
  active
  archived
  unmatched
}

enum NotificationType {
  like
  match
  message
  announcement
  approval
  payment
}

enum PaymentType {
  registration
  registration_premium
  premium_upgrade
  chat
}

enum RegistrationTier {
  basic
  premium
}

enum PaymentStatus {
  pending
  completed
  failed
}

enum AnnouncementAudience {
  all
  paid
  trial
  unpaid
}

enum StaffInviteStatus {
  pending
  accepted
  revoked
  expired
}

enum ReportStatus {
  open
  reviewed
  dismissed
}

enum ReportPriority {
  low
  medium
  high
}

enum SupportTopic {
  photo_upload
  account
  payment
  other
  contact_form
}

enum SupportSource {
  profile
  questionnaire
  contact_page
  other
}

enum SupportContactStatus {
  open
  reviewed
  closed
}

enum SupportAuthorRole {
  member
  admin
  visitor
}

enum MemberEmailKind {
  reminder_profile
  reminder_payment
  reminder_trial_ending
  reminder_signup_incomplete
  request_profile_photo
}

enum EvcStatus {
  pending
  approved
  rejected
}

enum MediaPurpose {
  profile_main
  profile_additional
  profile_private
  chat_image
  evc_screenshot
  support_attachment
  unknown
}

enum MediaMigrationStatus {
  pending
  uploaded
  verified
  failed
  skipped
}

enum MigrationRunStatus {
  pending
  running
  completed
  failed
  cancelled
}

enum PasswordAlgo {
  lucia_scrypt
  argon2id
  unknown
}

model User {
  id                     String    @id @default(uuid()) @db.Uuid
  convexId               String    @unique @map("convex_id")
  email                  String?   @unique
  emailNormalized        String?   @unique @map("email_normalized")
  name                   String?
  image                  String?
  phone                  String?
  emailVerificationTime  DateTime? @map("email_verification_time")
  phoneVerificationTime  DateTime? @map("phone_verification_time")
  isAnonymous            Boolean?  @map("is_anonymous")
  gender                 Gender?
  mustResetPassword      Boolean   @default(false) @map("must_reset_password")
  convexCreatedAt        DateTime? @map("convex_created_at")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  authAccounts       AuthAccount[]
  profile            Profile?
  preferences        Preference?
  uploads            UserUpload[]
  likesSent          Like[]            @relation("LikesSent")
  likesReceived      Like[]            @relation("LikesReceived")
  matchesAsA         Match[]           @relation("MatchUserA")
  matchesAsB         Match[]           @relation("MatchUserB")
  messagesSent       Message[]
  notifications      Notification[]
  payments           Payment[]
  announcementsCreated Announcement[]  @relation("AnnouncementCreator")
  staffInvitesSent   StaffInvite[]     @relation("StaffInviteSender")
  staffInvitesAccepted StaffInvite[]   @relation("StaffInviteAccepter")
  blocksCreated      Block[]           @relation("Blocker")
  blocksReceived     Block[]           @relation("Blocked")
  reportsFiled       Report[]          @relation("Reporter")
  reportsReceived    Report[]          @relation("Reported")
  reportsReviewed    Report[]          @relation("ReportReviewer")
  supportContacts    SupportContact[]
  supportMessages    SupportMessage[]
  supportReviewed    SupportContact[]  @relation("SupportReviewer")
  memberEmailLogs    MemberEmailLog[]
  auditLogsAsActor   AuditLog[]        @relation("AuditActor")
  auditLogsAsTarget  AuditLog[]        @relation("AuditTargetUser")
  evcProofs          EvcPaymentProof[]
  evcReviewed        EvcPaymentProof[] @relation("EvcReviewer")
  mediaObjects       MediaObject[]
  scoresAsA          CompatibilityScore[] @relation("ScoreUserA")
  scoresAsB          CompatibilityScore[] @relation("ScoreUserB")
  sessions           Session[]
  passwordResetTokens PasswordResetToken[]
  authAuditEvents    AuthAuditEvent[]
  photoRevealsViewed PhotoReveal[] @relation("PhotoRevealViewer")
  photoRevealsOwned  PhotoReveal[] @relation("PhotoRevealOwner")
  profileAuditEvents ProfileAuditEvent[]

  @@map("users")
}

model AuthAccount {
  id                   String       @id @default(uuid()) @db.Uuid
  convexId             String       @unique @map("convex_id")
  userId               String       @map("user_id") @db.Uuid
  convexUserId         String       @map("convex_user_id")
  provider             String
  providerAccountId    String       @map("provider_account_id")
  /// Lucia Scrypt hash (saltHex:keyHex). Never log this field.
  passwordHash         String?      @map("password_hash")
  passwordAlgo         PasswordAlgo @default(lucia_scrypt) @map("password_algo")
  emailVerified        Boolean?     @map("email_verified")
  phoneVerified        Boolean?     @map("phone_verified")
  convexCreatedAt      DateTime?    @map("convex_created_at")
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@index([convexUserId])
  @@map("auth_accounts")
}

model Profile {
  id                         String           @id @default(uuid()) @db.Uuid
  convexId                   String           @unique @map("convex_id")
  userId                     String           @unique @map("user_id") @db.Uuid
  convexUserId               String           @map("convex_user_id")
  name                       String
  gender                     Gender
  age                        Int
  height                     Int
  weight                     Int
  country                    String
  city                       String
  locationLat                Float?           @map("location_lat")
  locationLng                Float?           @map("location_lng")
  locationAccuracyM          Float?           @map("location_accuracy_m")
  locationVerifiedAt         DateTime?        @map("location_verified_at")
  education                  String
  occupation                 String
  religiousLevel             String           @map("religious_level")
  maritalStatus              String           @map("marital_status")
  children                   Int
  bio                        String
  profileImageConvexId       String?          @map("profile_image_convex_id")
  profileImageMediaId        String?          @map("profile_image_media_id") @db.Uuid
  verified                   Boolean
  role                       UserRole
  phone                      String?
  prayerFrequency            String           @map("prayer_frequency")
  spousePrayerImportance     String?          @map("spouse_prayer_importance")
  wearsHijab                 Boolean?         @map("wears_hijab")
  hasBeard                   Boolean?         @map("has_beard")
  smokes                     String
  substanceDetails           String?          @map("substance_details")
  drinksAlcohol              String           @map("drinks_alcohol")
  exercise                   String
  wantChildren               String           @map("want_children")
  familyInvolvement          String?          @map("family_involvement")
  livingSituation            String?          @map("living_situation")
  madhhab                    String?
  polygynyOpenness           String?          @map("polygyny_openness")
  hasCurrentWife             String?          @map("has_current_wife")
  openToSecondWife           String?          @map("open_to_second_wife")
  acceptManWithWife          String?          @map("accept_man_with_wife")
  acceptPreviouslyMarriedMan String?          @map("accept_previously_married_man")
  acceptFutureCoWife         String?          @map("accept_future_co_wife")
  languagesSpoken            String[]         @default([]) @map("languages_spoken")
  citizenshipStatus          String?          @map("citizenship_status")
  financialReadiness         String?          @map("financial_readiness")
  marriageWorkPreference     String?          @map("marriage_work_preference")
  marriageTimeline           String           @map("marriage_timeline")
  readyToRelocate            String?          @map("ready_to_relocate")
  loveLanguage               String?          @map("love_language")
  marrySomeoneWithChildren   String           @map("marry_someone_with_children")
  qualities                  String[]         @default([])
  hobbies                    String[]         @default([])
  questionnaireComplete      Boolean          @map("questionnaire_complete")
  questionnaireStep          Int?             @map("questionnaire_step")
  lastSavedAt                DateTime?        @map("last_saved_at")
  registrationComplete       Boolean?         @map("registration_complete")
  hasPaid                    Boolean          @map("has_paid")
  genderLocked               Boolean?         @map("gender_locked")
  trialEndsAt                DateTime?        @map("trial_ends_at")
  hasPersonalSupport         Boolean?         @map("has_personal_support")
  advisorReviewed            Boolean?         @map("advisor_reviewed")
  additionalImageConvexIds   String[]         @default([]) @map("additional_image_convex_ids")
  /// Nest-era additional photo media UUIDs (ordered). Migrated photos resolve via convex IDs.
  additionalImageMediaIds    String[]         @default([]) @map("additional_image_media_ids")
  privateImageConvexIds      String[]         @default([]) @map("private_image_convex_ids")
  privateImageMediaIds       String[]         @default([]) @map("private_image_media_ids")
  waliName                   String?          @map("wali_name")
  waliPhone                  String?          @map("wali_phone")
  banned                     Boolean
  approved                   Boolean
  reviewStatus               ReviewStatus?    @map("review_status")
  photoVisibility            PhotoVisibility? @map("photo_visibility")
  convexCreatedAt            DateTime?        @map("convex_created_at")
  createdAt                  DateTime         @default(now()) @map("created_at")
  updatedAt                  DateTime         @updatedAt @map("updated_at")

  user           User              @relation(fields: [userId], references: [id], onDelete: Restrict)
  auditTargets   AuditLog[]        @relation("AuditTargetProfile")
  evcProofs      EvcPaymentProof[]
  profileAudits  ProfileAuditEvent[]

  @@index([gender])
  @@index([country])
  @@index([approved])
  @@index([reviewStatus])
  @@index([role])
  @@index([convexUserId])
  @@map("profiles")
}

model Preference {
  id                 String   @id @default(uuid()) @db.Uuid
  convexId           String   @unique @map("convex_id")
  userId             String   @unique @map("user_id") @db.Uuid
  convexUserId       String   @map("convex_user_id")
  preferredGender    Gender   @map("preferred_gender")
  minAge             Int      @map("min_age")
  maxAge             Int      @map("max_age")
  minHeight          Int      @map("min_height")
  maxHeight          Int      @map("max_height")
  preferredCountries String[] @default([]) @map("preferred_countries")
  acceptChildren     String   @map("accept_children")
  educationLevel     String   @map("education_level")
  religiousLevel     String?  @map("religious_level")
  acceptDivorcee     String   @map("accept_divorcee")
  acceptWidow        String   @map("accept_widow")
  maxDistance        String?  @map("max_distance")
  qualities          String[] @default([])
  hobbies            String[] @default([])
  partnerBeard       String?  @map("partner_beard")
  partnerHijabLevel  String?  @map("partner_hijab_level")
  readyToRelocate    String?  @map("ready_to_relocate")
  convexCreatedAt    DateTime? @map("convex_created_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([convexUserId])
  @@map("preferences")
}

model CompatibilityScore {
  id               String    @id @default(uuid()) @db.Uuid
  convexId         String    @unique @map("convex_id")
  userAId          String    @map("user_a_id") @db.Uuid
  userBId          String    @map("user_b_id") @db.Uuid
  convexUserA      String    @map("convex_user_a")
  convexUserB      String    @map("convex_user_b")
  score            Float
  scoreVersion     Int       @default(1) @map("score_version")
  lastCalculatedAt DateTime? @map("last_calculated_at")
  convexCreatedAt  DateTime? @map("convex_created_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  userA User @relation("ScoreUserA", fields: [userAId], references: [id], onDelete: Restrict)
  userB User @relation("ScoreUserB", fields: [userBId], references: [id], onDelete: Restrict)

  @@unique([userAId, userBId])
  @@index([userAId, score])
  @@index([userBId, score])
  @@index([scoreVersion])
  @@map("compatibility_scores")
}

model Like {
  id               String     @id @default(uuid()) @db.Uuid
  convexId         String     @unique @map("convex_id")
  fromUserId       String     @map("from_user_id") @db.Uuid
  toUserId         String     @map("to_user_id") @db.Uuid
  convexFromUserId String     @map("convex_from_user_id")
  convexToUserId   String     @map("convex_to_user_id")
  action           LikeAction
  convexCreatedAt  DateTime?  @map("convex_created_at")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  fromUser User @relation("LikesSent", fields: [fromUserId], references: [id], onDelete: Restrict)
  toUser   User @relation("LikesReceived", fields: [toUserId], references: [id], onDelete: Restrict)

  @@unique([fromUserId, toUserId])
  @@index([toUserId])
  @@index([fromUserId, action])
  @@index([toUserId, action])
  @@map("likes")
}

model Match {
  id              String      @id @default(uuid()) @db.Uuid
  convexId        String      @unique @map("convex_id")
  /// Deterministic unordered pair: min(uuid):max(uuid)
  pairKey         String      @unique @map("pair_key")
  userAId         String      @map("user_a_id") @db.Uuid
  userBId         String      @map("user_b_id") @db.Uuid
  convexUserA     String      @map("convex_user_a")
  convexUserB     String      @map("convex_user_b")
  score           Float
  status          MatchStatus
  chatUnlocked    Boolean     @map("chat_unlocked")
  seenAtByUser    Json?       @map("seen_at_by_user")
  archivedAt      DateTime?   @map("archived_at")
  convexCreatedAt DateTime?   @map("convex_created_at")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  userA        User          @relation("MatchUserA", fields: [userAId], references: [id], onDelete: Restrict)
  userB        User          @relation("MatchUserB", fields: [userBId], references: [id], onDelete: Restrict)
  conversation Conversation?
  payments     Payment[]
  photoReveals PhotoReveal[]

  @@unique([userAId, userBId])
  @@index([userAId, status])
  @@index([userBId, status])
  @@index([status, archivedAt])
  @@map("matches")
}

/**
 * One-time private photo unlock within an active mutual match.
 * Viewer spends a reveal credit to permanently unlock one private photo
 * for that match (while the match stays active).
 */
model PhotoReveal {
  id           String   @id @default(uuid()) @db.Uuid
  matchId      String   @map("match_id") @db.Uuid
  viewerUserId String   @map("viewer_user_id") @db.Uuid
  ownerUserId  String   @map("owner_user_id") @db.Uuid
  mediaId      String   @map("media_id") @db.Uuid
  revealedAt   DateTime @default(now()) @map("revealed_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  match  Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  viewer User  @relation("PhotoRevealViewer", fields: [viewerUserId], references: [id], onDelete: Restrict)
  owner  User  @relation("PhotoRevealOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)

  @@unique([matchId, viewerUserId, mediaId])
  @@index([matchId, viewerUserId])
  @@index([ownerUserId])
  @@map("photo_reveals")
}

model Conversation {
  id                   String   @id @default(uuid()) @db.Uuid
  convexId             String   @unique @map("convex_id")
  matchId              String   @unique @map("match_id") @db.Uuid
  convexMatchId        String   @map("convex_match_id")
  participantConvexIds String[] @default([]) @map("participant_convex_ids")
  /// Postgres user UUIDs for authorization (backfilled from match).
  participantUserIds   String[] @default([]) @map("participant_user_ids")
  lastMessageAt        DateTime @map("last_message_at")
  unreadByUser         Json?    @map("unread_by_user")
  /// Daily photo streak (both partners send a chat photo on the same UTC day).
  streakCount          Int      @default(0) @map("streak_count")
  longestStreak        Int      @default(0) @map("longest_streak")
  streakLastDay        String?  @map("streak_last_day")
  streakPendingDay     String?  @map("streak_pending_day")
  streakPendingUserIds Json?    @map("streak_pending_user_ids")
  convexCreatedAt      DateTime? @map("convex_created_at")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  match    Match     @relation(fields: [matchId], references: [id], onDelete: Restrict)
  messages Message[]

  @@index([lastMessageAt])
  @@map("conversations")
}

model Message {
  id                   String   @id @default(uuid()) @db.Uuid
  convexId             String   @unique @map("convex_id")
  conversationId       String   @map("conversation_id") @db.Uuid
  convexConversationId String   @map("convex_conversation_id")
  senderId             String   @map("sender_id") @db.Uuid
  convexSenderId       String   @map("convex_sender_id")
  body                 String
  imageConvexId        String?  @map("image_convex_id")
  imageMediaId         String?  @map("image_media_id") @db.Uuid
  /// Client/retry idempotency — unique per conversation when present.
  idempotencyKey       String?  @map("idempotency_key")
  read                 Boolean
  messageCreatedAt     DateTime @map("message_created_at")
  convexCreatedAt      DateTime? @map("convex_created_at")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Restrict)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Restrict)

  @@unique([conversationId, idempotencyKey])
  @@index([conversationId, messageCreatedAt])
  @@index([senderId])
  @@map("messages")
}

model Notification {
  id                    String           @id @default(uuid()) @db.Uuid
  convexId              String           @unique @map("convex_id")
  userId                String           @map("user_id") @db.Uuid
  convexUserId          String           @map("convex_user_id")
  type                  NotificationType
  title                 String
  body                  String
  read                  Boolean
  relatedUserId         String?          @map("related_user_id") @db.Uuid
  convexRelatedUserId   String?          @map("convex_related_user_id")
  /// Dedup key for retried side-effects (e.g. message:{messageId}).
  sourceKey             String?          @unique @map("source_key")
  notificationCreatedAt DateTime         @map("notification_created_at")
  convexCreatedAt       DateTime?        @map("convex_created_at")
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId, notificationCreatedAt])
  @@index([userId, read])
  @@map("notifications")
}

model Payment {
  id                 String            @id @default(uuid()) @db.Uuid
  convexId           String            @unique @map("convex_id")
  userId             String            @map("user_id") @db.Uuid
  convexUserId       String            @map("convex_user_id")
  stripeSessionId    String            @unique @map("stripe_session_id")
  amount             Int
  paymentType        PaymentType?      @map("payment_type")
  registrationTier   RegistrationTier? @map("registration_tier")
  matchId            String?           @map("match_id") @db.Uuid
  convexMatchId      String?           @map("convex_match_id")
  status             PaymentStatus
  /// When fulfillment completed (Stripe webhook/verify or EVC approve).
  fulfilledAt        DateTime?         @map("fulfilled_at")
  /// Idempotency key for grant path: stripe:{sessionId} | evc:{proofId}
  fulfillmentKey     String?           @unique @map("fulfillment_key")
  paymentCreatedAt   DateTime          @map("payment_created_at")
  convexCreatedAt    DateTime?         @map("convex_created_at")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  user  User   @relation(fields: [userId], references: [id], onDelete: Restrict)
  match Match? @relation(fields: [matchId], references: [id], onDelete: Restrict)

  @@index([userId, status])
  @@index([status, paymentCreatedAt])
  @@map("payments")
}

model Announcement {
  id              String                 @id @default(uuid()) @db.Uuid
  convexId        String                 @unique @map("convex_id")
  title           String
  body            String
  announcementCreatedAt DateTime         @map("announcement_created_at")
  createdById     String                 @map("created_by_id") @db.Uuid
  convexCreatedBy String                 @map("convex_created_by")
  scheduledFor    DateTime?              @map("scheduled_for")
  sentAt          DateTime?              @map("sent_at")
  audience        AnnouncementAudience?
  convexCreatedAt DateTime?              @map("convex_created_at")
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")

  createdBy User @relation("AnnouncementCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@map("announcements")
}

model UserUpload {
  id               String   @id @default(uuid()) @db.Uuid
  convexId         String   @unique @map("convex_id")
  userId           String   @map("user_id") @db.Uuid
  convexUserId     String   @map("convex_user_id")
  convexStorageId  String   @unique @map("convex_storage_id")
  mediaObjectId    String?  @map("media_object_id") @db.Uuid
  uploadedAt       DateTime @map("uploaded_at")
  convexCreatedAt  DateTime? @map("convex_created_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user        User         @relation(fields: [userId], references: [id], onDelete: Restrict)
  mediaObject MediaObject? @relation(fields: [mediaObjectId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@map("user_uploads")
}

model StaffInvite {
  id                   String            @id @default(uuid()) @db.Uuid
  convexId             String            @unique @map("convex_id")
  email                String
  /// Migrated Convex invites keep plaintext token for lookup; new Nest invites prefer tokenHash.
  token                String            @unique
  /// SHA-256 hex of invite token (new invites). Null for migrated plaintext-only rows.
  tokenHash            String?           @unique @map("token_hash")
  role                 UserRole          @default(admin)
  invitedById          String            @map("invited_by_id") @db.Uuid
  convexInvitedBy      String            @map("convex_invited_by")
  status               StaffInviteStatus
  inviteCreatedAt      DateTime          @map("invite_created_at")
  expiresAt            DateTime          @map("expires_at")
  acceptedAt           DateTime?         @map("accepted_at")
  acceptedByUserId     String?           @map("accepted_by_user_id") @db.Uuid
  convexAcceptedByUserId String?         @map("convex_accepted_by_user_id")
  convexCreatedAt      DateTime?         @map("convex_created_at")
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt @map("updated_at")

  invitedBy  User  @relation("StaffInviteSender", fields: [invitedById], references: [id], onDelete: Restrict)
  acceptedBy User? @relation("StaffInviteAccepter", fields: [acceptedByUserId], references: [id], onDelete: Restrict)

  @@index([email])
  @@index([status])
  @@map("staff_invites")
}

model Block {
  id                String   @id @default(uuid()) @db.Uuid
  convexId          String   @unique @map("convex_id")
  blockerId         String   @map("blocker_id") @db.Uuid
  blockedId         String   @map("blocked_id") @db.Uuid
  convexBlockerId   String   @map("convex_blocker_id")
  convexBlockedId   String   @map("convex_blocked_id")
  blockedAt         DateTime @map("blocked_at")
  convexCreatedAt   DateTime? @map("convex_created_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  blocker User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Restrict)
  blocked User @relation("Blocked", fields: [blockedId], references: [id], onDelete: Restrict)

  @@unique([blockerId, blockedId])
  @@index([blockedId])
  @@map("blocks")
}

model Report {
  id                  String          @id @default(uuid()) @db.Uuid
  convexId            String          @unique @map("convex_id")
  reporterId          String          @map("reporter_id") @db.Uuid
