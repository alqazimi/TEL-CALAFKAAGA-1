# Local API environment (copy to .env — never commit secrets)
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# PostgreSQL — local Docker Compose only
DATABASE_URL=postgresql://hel:hel_dev_change_me@localhost:5432/hel_calafkaaga?schema=public

# Redis — BullMQ score queue + rate limits (Phase 6)
REDIS_URL=redis://127.0.0.1:6379

# MinIO / S3-compatible object storage (local Phase 3 only — NOT Cloudflare R2)
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=helminio
S3_SECRET_ACCESS_KEY=hel_minio_dev_change_me
S3_FORCE_PATH_STYLE=true
S3_SIGNED_URL_TTL_SECONDS=300

# Private buckets by purpose (created by infra/minio-init.sh)
S3_BUCKET_PROFILE=hel-profile
S3_BUCKET_PROFILE_PRIVATE=hel-profile-private
S3_BUCKET_CHAT=hel-chat
S3_BUCKET_SUPPORT=hel-support
S3_BUCKET_EVC=hel-evc

# Phase 4 auth (local only — never use production Resend here)
SESSION_SECRET=hel_dev_session_secret_change_me_32
COOKIE_SECURE=false
COOKIE_DOMAIN=
CORS_ORIGINS=http://localhost:3020,http://127.0.0.1:3020,http://localhost:3001,http://127.0.0.1:3001
TRUST_PROXY=false
APP_URL=http://localhost:3020
MAIL_DRIVER=console
# MAIL_DRIVER=resend requires RESEND_API_KEY — never point at production users locally
# RESEND_API_KEY=
# RESEND_FROM=Hel Calafkaaga <hello@helcalafkaaga.com>

# Stripe test mode only (Phase 8). Use STRIPE_GATEWAY=fake for automated tests.
STRIPE_GATEWAY=fake
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_test_replace_me
# STRIPE_ALLOW_LIVE must never be true in local Phase 8
