# Convex (required — set in Vercel/hosting for production builds)
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# App — production custom domain
NEXT_PUBLIC_APP_URL=https://helcalafkaaga.com

# Stripe (publishable key is safe for the browser)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe secret key — set on Convex (NOT in Next.js client):
#   npx convex env set STRIPE_SECRET_KEY sk_live_...
# For production:
#   npx convex env set STRIPE_SECRET_KEY sk_live_... --prod

# Stripe webhook secret — set on Convex after creating webhook endpoint:
#   npx convex env set STRIPE_WEBHOOK_SECRET whsec_...
# For production:
#   npx convex env set STRIPE_WEBHOOK_SECRET whsec_... --prod
# Webhook URL (prod): https://YOUR-PROD-DEPLOYMENT.convex.site/stripe/webhook
# Event: checkout.session.completed

# Setup scripts (see README production section)
#   npm run setup:auth:prod
#   npm run setup:stripe:prod -- sk_live_...
#   npm run setup:resend:prod -- re_...
#   npm run deploy:checklist
# JWT_PRIVATE_KEY - set automatically by setup script
# JWKS - set automatically by setup script
# SITE_URL - your app URL, e.g. https://helcalafkaaga.com

# Password reset & contact form emails (set on Convex)
#   npx convex env set AUTH_RESEND_KEY re_...
#   npx convex env set AUTH_EMAIL_FROM "Calaf <hello@helcalafkaaga.com>" --prod
#   npx convex env set SUPPORT_EMAIL hello@helcalafkaaga.com --prod
# For production:
#   npx convex env set AUTH_RESEND_KEY re_... --prod

# First owner bootstrap (Convex only — never expose in Next.js)
# Generate a long random secret, then set on Convex:
#   openssl rand -base64 32
#   npx convex env set ADMIN_BOOTSTRAP_EMAIL you@example.com
#   npx convex env set ADMIN_BOOTSTRAP_SECRET <paste-secret-here>
# For production:
#   npx convex env set ADMIN_BOOTSTRAP_EMAIL you@example.com --prod
#   npx convex env set ADMIN_BOOTSTRAP_SECRET <paste-secret-here> --prod
# Then register/login with that email and open /admin to claim the owner role.
# The owner gets free access (no payment) and can promote users to admin.
