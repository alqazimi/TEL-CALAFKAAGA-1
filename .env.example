# Convex (required — set in Vercel/hosting for production builds)
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Auth (set on Convex deployment via scripts/setup-convex-auth.mjs)
# JWT_PRIVATE_KEY - set automatically by setup script
# JWKS - set automatically by setup script
# SITE_URL - your app URL, e.g. http://localhost:3001
