# Nest API (required)
NEXT_PUBLIC_API_URL=http://127.0.0.1:3001
NEXT_PUBLIC_SOCKET_URL=http://127.0.0.1:3001

# App — production custom domain
NEXT_PUBLIC_APP_URL=https://helcalafkaaga.com

# Google Analytics 4 — all-site traffic (WhatsApp, direct, ads, Search, etc.)
# Create at https://analytics.google.com → Admin → Data streams → Web
# Then set on Vercel: NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-R2KHEZ77P6

# Stripe (publishable key is safe for the browser)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe secret / webhook secret — set on the Nest API host (Render), not in Next.js:
#   STRIPE_SECRET_KEY=sk_live_...
#   STRIPE_WEBHOOK_SECRET=whsec_...
# Webhook URL: https://YOUR-API-HOST/webhooks/stripe
# Event: checkout.session.completed

# Coming soon / maintenance page (Next.js middleware → /maintenance.html)
# OFF by default. To enable on Vercel:
#   MAINTENANCE_MODE=true
# MAINTENANCE_MODE=
