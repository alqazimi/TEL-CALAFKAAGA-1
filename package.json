{
  "name": "calaf",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:next",
    "dev:next": "next dev",
    "dev:convex": "convex dev",
    "dev:all": "convex dev & next dev",
    "dev:api": "npm run start:dev -w @hel/api",
    "setup:auth": "node scripts/setup-convex-auth.mjs",
    "setup:auth:prod": "node scripts/setup-convex-auth.mjs --prod",
    "setup:stripe": "node scripts/setup-stripe.mjs",
    "setup:stripe:prod": "node scripts/setup-stripe.mjs --prod",
    "fix:stripe:prod": "node scripts/fix-stripe-prod.mjs",
    "setup:resend": "node scripts/setup-resend.mjs",
    "setup:resend:prod": "node scripts/setup-resend.mjs --prod",
    "deploy:checklist": "node scripts/deploy-checklist.mjs",
    "convex:webhook-url": "node scripts/print-convex-webhook-url.mjs",
    "convex:webhook-url:prod": "node scripts/print-convex-webhook-url.mjs --prod",
    "preflight": "node scripts/preflight.mjs",
    "preflight:prod": "node scripts/preflight.mjs --prod",
    "bootstrap:admin": "node scripts/bootstrap-admin.mjs",
    "bootstrap:admin:prod": "node scripts/bootstrap-admin.mjs --prod",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "prisma:generate": "npm run prisma:generate -w @hel/api",
    "prisma:validate": "npm run prisma:validate -w @hel/api",
    "migration:inspect": "npm run inspect -w @hel/migration --",
    "migration:inspect-auth": "npm run inspect-auth -w @hel/migration --",
    "migration:dry-run": "npm run dry-run -w @hel/migration --",
    "migration:import-core": "npm run import-core -w @hel/migration --",
    "migration:import-domain": "npm run import-domain -w @hel/migration --",
    "migration:inspect-storage": "npm run inspect-storage -w @hel/migration --",
    "migration:import-files": "npm run import-files -w @hel/migration --",
    "migration:validate": "npm run validate -w @hel/migration --",
    "migration:validate-domain": "npm run validate-domain -w @hel/migration --",
    "migration:validate-files": "npm run validate-files -w @hel/migration --",
    "migration:test": "npm run test -w @hel/migration",
    "auth:test": "npm run test -w @hel/api",
    "auth:smoke": "npm run auth:smoke -w @hel/api --",
    "frontend:convex-deps": "node scripts/report-direct-convex-deps.mjs",
    "frontend:convex-deps:check": "node scripts/report-direct-convex-deps.mjs --fail",
    "test:frontend": "tsx --test src/data/**/*.test.ts src/data/shadow/**/*.test.ts",
    "test:e2e:staging": "playwright test",
    "test:shadow": "tsx --test src/data/shadow/**/*.test.ts",
    "stack:local:api": "bash scripts/staging/start-local-api-stack.sh",
    "staging:validate-counts": "tsx scripts/staging/validate-counts.ts",
    "staging:load-smoke": "node scripts/staging/load-smoke.mjs",
    "staging:seed-users": "tsx scripts/staging/seed-staging-test-users.ts",
    "staging:local-smoke": "bash scripts/staging/run-local-staging-smoke.sh",
    "staging:prepare-snapshot": "tsx scripts/staging/prepare-staging-snapshot.ts",
    "staging:clone-db": "bash scripts/staging/clone-local-to-staging-db.sh",
    "staging:validate-media": "node scripts/staging/validate-media.mjs",
    "staging:backup-restore-test": "bash scripts/staging/backup-restore-test.sh",
    "phase12:validate": "bash scripts/staging/run-phase12-validation.sh"
  },
  "dependencies": {
    "@auth/core": "^0.41.1",
    "@convex-dev/auth": "^0.0.94",
    "@hookform/resolvers": "^5.4.0",
    "@next/third-parties": "^16.2.10",
    "@oslojs/crypto": "^1.0.1",
    "@radix-ui/react-avatar": "^1.2.1",
    "@radix-ui/react-checkbox": "^1.3.6",
    "@radix-ui/react-dialog": "^1.1.18",
    "@radix-ui/react-dropdown-menu": "^2.1.19",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-popover": "^1.1.18",
    "@radix-ui/react-progress": "^1.1.11",
    "@radix-ui/react-radio-group": "^1.4.2",
    "@radix-ui/react-scroll-area": "^1.2.13",
    "@radix-ui/react-select": "^2.3.2",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.2",
    "@radix-ui/react-tabs": "^1.1.16",
    "@radix-ui/react-tooltip": "^1.2.11",
    "@stripe/stripe-js": "^9.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.42.1",
    "date-fns": "^4.4.0",
    "emoji-picker-react": "^4.19.1",
    "framer-motion": "^12.42.2",
    "libphonenumber-js": "^1.13.8",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.81.0",
    "react-phone-number-input": "^3.4.17",
    "resend": "^6.17.1",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "stripe": "^22.3.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5"
  }
}
