# Paste into Vercel → Project → Settings → Environment Variables
# Preview / staging for: https://tel-calafkaaga-1-api-one.vercel.app
#
# IMPORTANT: These NEXT_PUBLIC_* vars must be set BEFORE / during the Vercel
# build (not only runtime). After changing them, trigger a Redeploy.
#
# Do not point API_URL / SOCKET_URL at the Vercel frontend URL.

NEXT_PUBLIC_BACKEND_PROVIDER=api
NEXT_PUBLIC_APP_URL=https://tel-calafkaaga-1-api-one.vercel.app
NEXT_PUBLIC_API_URL=https://tel-calafkaaga-1.onrender.com
NEXT_PUBLIC_SOCKET_URL=https://tel-calafkaaga-1.onrender.com

# ---------------------------------------------------------------------------
# Render Nest service env (Dashboard → tel-calafkaaga-1 → Environment)
# Paste these — then Manual Deploy / restart. Fixes browser CORS errors.
# ---------------------------------------------------------------------------
CORS_ORIGINS=https://tel-calafkaaga-1-api-one.vercel.app
APP_URL=https://tel-calafkaaga-1-api-one.vercel.app
COOKIE_SECURE=true
COOKIE_SAMESITE=none
TRUST_PROXY=true
# DATABASE_URL=<Render Postgres URL>
# REDIS_URL=...
# SESSION_SECRET=<min 32 chars>
# S3_* = Cloudflare R2 or other public cloud bucket (not localhost MinIO)
